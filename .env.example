# Neon PostgreSQL bağlantı dizesi. Sunucu tarafında kullanılır (NEXT_PUBLIC_
# öneki YOKTUR, istemci bundle'ına dahil edilmez). Gerçek değeri buraya
# yazmayın — bu dosya yalnızca örnektir ve versiyon kontrolüne dahildir.
# Kendi değerinizi, commit edilmeyen .env.local dosyasına yazın.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
